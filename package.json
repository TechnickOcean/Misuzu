{
  "name": "misuzu-core",
  "type": "module",
  "scripts": {
    "db:push": "bunx drizzle-kit push",
    "web:dev": "bun run --cwd apps/web dev",
    "web:build": "bun run --cwd apps/web build",
    "web:preview": "bun run --cwd apps/web preview",
    "server:dev": "bun run --cwd apps/server dev",
    "server:start": "bun run --cwd apps/server start",
    "dev": "concurrently -n web,server -c cyan,magenta \"bun run web:dev\" \"bun --env-file=.env run server:dev \"",
    "code:check": "bunx biome check --write"
  },
  "devDependencies": {
    "@biomejs/biome": "2.3.15",
    "@types/bun": "^1.3.9",
    "concurrently": "^9.2.1",
    "drizzle-kit": "^0.31.9"
  },
  "peerDependencies": {
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@libsql/client": "^0.17.0",
    "@octokit/rest": "^22.0.1",
    "ai-gateway-provider": "^3.1.1",
    "better-sqlite3": "^12.6.2",
    "drizzle-orm": "^0.45.1",
    "openai": "^6.25.0",
    "pino": "^10.3.1",
    "sanitize-filename": "^1.6.3",
    "zod": "^4.3.6"
  }
}
