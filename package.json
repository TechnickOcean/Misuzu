      "@mariozechner/pi-tui": "^0.63.1",
      "@sinclair/typebox": "^0.34.48",
      "@types/node": "^24.12.0",
      "dotenv": "^17.3.1",
      "glob": "^13.0.6",
      "tsx": "^4.21.0",
      "typescript": "^5",
      "vite": "npm:@voidzero-dev/vite-plus-core@latest",
